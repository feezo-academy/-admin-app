
DECLARE
  v_total           int;
  v_signups_week    int;
  v_signups_month   int;
  v_active_trials   int;
  v_paying          int;
  v_frozen          int;
  v_expiring_3d     int;
  v_renew_7d        int;
  v_mrr             numeric;
  v_arr             numeric;
  v_conversion      numeric;
  v_trials_total    int;
  v_trials_converted int;
  v_signups_30d     jsonb;
BEGIN
  IF NOT public.is_superadmin() THEN
    RAISE EXCEPTION 'Forbidden: superadmin role required';
  END IF;

  SELECT count(*) INTO v_total FROM public.academies;
  SELECT count(*) INTO v_signups_week  FROM public.academies WHERE created_at >= now() - interval '7 days';
  SELECT count(*) INTO v_signups_month FROM public.academies WHERE created_at >= now() - interval '30 days';
  SELECT count(*) INTO v_active_trials FROM public.academies WHERE plan = 'trial' AND trial_ends_at > now();
  SELECT count(*) INTO v_paying        FROM public.academies WHERE plan IN ('basic','pro','premium') AND plan_ends_at > now();
  SELECT count(*) INTO v_frozen        FROM public.academies
    WHERE plan = 'frozen'
       OR (plan = 'trial' AND trial_ends_at < now())
       OR (plan IN ('basic','pro','premium') AND plan_ends_at < now());

  SELECT count(*) INTO v_expiring_3d
  FROM public.academies
  WHERE plan = 'trial' AND trial_ends_at BETWEEN now() AND now() + interval '3 days';

  SELECT count(*) INTO v_renew_7d
  FROM public.academies
  WHERE plan IN ('basic','pro','premium')
    AND plan_ends_at BETWEEN now() AND now() + interval '7 days';

  SELECT COALESCE(SUM(
    CASE
      WHEN p.price_annual IS NOT NULL AND a.plan_ends_at > now() + interval '6 months'
        THEN p.price_annual / 12.0
      ELSE p.price_monthly
    END
  ), 0)
  INTO v_mrr
  FROM public.academies a
  JOIN public.plans p ON p.code = a.plan
  WHERE a.plan IN ('basic','pro','premium') AND a.plan_ends_at > now();
  v_arr := v_mrr * 12;

  SELECT count(*) INTO v_trials_total
  FROM public.academies WHERE created_at >= now() - interval '90 days';
  SELECT count(*) INTO v_trials_converted
  FROM public.academies
  WHERE created_at >= now() - interval '90 days'
    AND plan IN ('basic','pro','premium');
  v_conversion := CASE WHEN v_trials_total > 0
    THEN ROUND(v_trials_converted::numeric / v_trials_total::numeric * 100, 1)
    ELSE 0 END;

  SELECT jsonb_agg(jsonb_build_object('date', day, 'count', cnt) ORDER BY day) INTO v_signups_30d
  FROM (
    SELECT
      to_char(d::date, 'YYYY-MM-DD') AS day,
      (SELECT count(*) FROM public.academies WHERE created_at::date = d::date) AS cnt
    FROM generate_series(
      (now() - interval '29 days')::date,
      now()::date,
      interval '1 day'
    ) d
  ) sub;

  RETURN jsonb_build_object(
    'total_academies',       v_total,
    'signups_week',          v_signups_week,
    'signups_month',         v_signups_month,
    'active_trials',         v_active_trials,
    'paying',                v_paying,
    'frozen',                v_frozen,
    'expiring_3d',           v_expiring_3d,
    'renew_7d',              v_renew_7d,
    'mrr',                   ROUND(v_mrr, 2),
    'arr',                   ROUND(v_arr, 2),
    'conversion_pct',        v_conversion,
    'trials_total_90d',      v_trials_total,
    'trials_converted_90d',  v_trials_converted,
    'signups_30d',           v_signups_30d
  );
END 
